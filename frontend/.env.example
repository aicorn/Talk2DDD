# Next.js Frontend Environment Variables
# BACKEND_URL is used server-side for proxying /api/* requests to the backend.
# In Docker Compose this is set automatically to http://backend:8000.
# For local development (npm run dev) the default is http://localhost:8000.
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Talk2DDD
NEXT_PUBLIC_APP_VERSION=0.1.0
