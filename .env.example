# Application Settings
APP_NAME=Talk2DDD
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production

# Database
DB_PASSWORD=your-secure-database-password

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars

# AI Provider selection: "openai", "deepseek", or "minimax"
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key-here
# Domestic China endpoint (default, works inside China):
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# International endpoint (use if you are outside China):
# MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01

# Frontend
NODE_ENV=production
FRONTEND_PORT=3000
